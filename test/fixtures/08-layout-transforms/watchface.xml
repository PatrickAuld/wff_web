<WatchFace width="450" height="450">
  <Scene backgroundColor="#000000">
    <!-- Basic positioning: red rectangle at (50,50) -->
    <Group x="50" y="50" width="100" height="100">
      <Rectangle x="0" y="0" width="100" height="100">
        <Fill color="#FF0000"/>
      </Rectangle>
    </Group>

    <!-- Rotation: 45 degrees around center -->
    <Group x="200" y="50" width="100" height="100" angle="45">
      <Rectangle x="0" y="0" width="100" height="100">
        <Fill color="#00FF00"/>
      </Rectangle>
    </Group>

    <!-- Alpha: ~50% opacity (128/255) blue rectangle -->
    <Group x="50" y="200" width="100" height="100" alpha="128">
      <Rectangle x="0" y="0" width="100" height="100">
        <Fill color="#0000FF"/>
      </Rectangle>
    </Group>

    <!-- Scale: 0.5x scale around center -->
    <Group x="200" y="200" width="100" height="100" scaleX="0.5" scaleY="0.5">
      <Rectangle x="0" y="0" width="100" height="100">
        <Fill color="#FFFF00"/>
      </Rectangle>
    </Group>

    <!-- Nested groups: outer translates, inner translates and rotates -->
    <Group x="350" y="50" width="80" height="80">
      <Group x="10" y="10" width="60" height="60" angle="45">
        <Rectangle x="0" y="0" width="60" height="60">
          <Fill color="#FF00FF"/>
        </Rectangle>
      </Group>
    </Group>

    <!-- PartDraw: cyan rectangle via PartDraw container -->
    <PartDraw x="50" y="350" width="100" height="80">
      <Rectangle x="0" y="0" width="100" height="80">
        <Fill color="#00FFFF"/>
      </Rectangle>
    </PartDraw>

    <!-- Group with PartDraw child -->
    <Group x="200" y="350" width="150" height="80">
      <PartDraw x="10" y="10" width="130" height="60">
        <Rectangle x="0" y="0" width="130" height="60">
          <Fill color="#FF8000"/>
        </Rectangle>
      </PartDraw>
    </Group>
  </Scene>
</WatchFace>
