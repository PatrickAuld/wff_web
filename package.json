{
  "name": "wff-web",
  "version": "0.1.0",
  "description": "Web preview renderer for WearOS Watch Face Format (WFF) v4 XML",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:visual": "vitest run --config vitest.visual.config.ts",
    "test:visual:update-baselines": "tsx scripts/update-baselines.ts",
    "report": "tsx scripts/generate-report.ts"
  },
  "keywords": [
    "wearos",
    "watch-face",
    "wff",
    "watch-face-format",
    "canvas",
    "renderer",
    "preview"
  ],
  "author": "Patrick Auld",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/PatrickAuld/wff_web.git"
  },
  "bugs": {
    "url": "https://github.com/PatrickAuld/wff_web/issues"
  },
  "homepage": "https://github.com/PatrickAuld/wff_web#readme",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.31.0",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "@types/pngjs": "^6.0.5",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
