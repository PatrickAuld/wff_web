{
  "name": "wff-web",
  "version": "0.1.0",
  "description": "Web preview renderer for WearOS Watch Face Format (WFF) v4 XML",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "test:visual": "vitest run --config vitest.visual.config.ts",
    "test:visual:update-baselines": "tsx scripts/update-baselines.ts",
    "report": "tsx scripts/generate-report.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.31.0",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/pngjs": "^6.0.5",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
